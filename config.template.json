{
  "_comment": "Configuration template for Privacy-Compliant Benchmarking Tool",
  "_instructions": "Copy this file to config.json and customize as needed",
  
  "column_mappings": {
    "_comment": "Map your column names to standard names",
    "_example": {
      "your_entity_column": "entity_identifier",
      "your_count_column": "transaction_count",
      "your_amount_column": "transaction_amount"
    }
  },
  
  "comparison_metrics": {
    "_comment": "Metrics used for peer similarity calculation",
    "rate": [
      "approved_count",
      "total_count",
      "fraud_count"
    ],
    "share": [
      "transaction_count"
    ],
    "volume": [
      "transaction_count",
      "transaction_amount"
    ]
  },
  
  "dimension_metrics": {
    "_comment": "Custom metrics for specific dimensions",
    "_example": {
      "Region": ["approved_count", "total_count"],
      "Product": ["transaction_count", "transaction_amount"]
    }
  },
  
  "privacy_rules": {
    "_comment": "Privacy rule configurations",
    "default_rule": "5/25",
    "fallback_order": ["5/25", "6/30", "7/35", "10/40"],
    "protected_entities": [],
    "protected_max_concentration": 25.0
  },
  
  "analysis_settings": {
    "_comment": "Default analysis parameters",
    "default_participants": 5,
    "default_max_concentration": 25.0,
    "default_n_peers": 10,
    "default_combinations": [1, 2, 3],
    "default_max_combinations": 5,
    "best_in_class_percentile": 0.85,
    "fraud_bps_percentile": 0.15
  },
  
  "output_settings": {
    "_comment": "Output configuration",
    "default_format": "excel",
    "output_directory": "output",
    "log_directory": "logs",
    "include_metadata_sheet": true,
    "include_audit_log": true
  },
  
  "sql": {
    "_comment": "SQL database connection settings (optional)",
    "_note": "Use connection_string OR individual parameters",
    "connection_string": "",
    "driver": "SQL Server",
    "server": "localhost",
    "database": "benchmarks",
    "uid": "",
    "pwd": "",
    "use_trusted_connection": true
  },
  
  "advanced": {
    "_comment": "Advanced settings - use with caution",
    "enable_weighting": true,
    "enable_fallback_rules": true,
    "remove_zero_values": true,
    "scale_features_for_distance": true,
    "distance_metric": "euclidean",
    "minimum_data_quality_threshold": 0.8
  }
}
